---
import { getCollection } from "astro:content";
import { getSortedPosts } from "@/utils/getSortedPosts";

const posts = await getCollection("posts");
const featuredPosts = getSortedPosts(posts).filter(({ data }) => data.featured).slice(0, 5);
---

<div class="relative w-full overflow-hidden rounded-2xl">
  <div class="flex snap-x snap-mandatory overflow-x-auto scrollbar-hide h-80">
    {featuredPosts.map((post) => (
      <div class="min-w-full snap-center relative">
        <img 
          src={post.data.ogImage ?? "/default-og.png"} 
          alt={post.data.title}
          class="w-full h-full object-cover"
        />
        <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/80 to-transparent text-white">
          <h3 class="text-2xl font-bold">{post.data.title}</h3>
          <a href={`/posts/${post.slug}`} class="text-accent underline hover:text-white">Read Story</a>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
