---
import { getCollection } from "astro:content";
import { getSortedPosts } from "@/utils/getSortedPosts";

const posts = await getCollection("posts");
const featuredPosts = getSortedPosts(posts).filter(({ data }) => data.featured).slice(0, 5);
---

<div class="relative w-full h-80 overflow-hidden rounded-xl bg-gray-900">
  <div class="flex transition-transform duration-500 ease-out" id="slider-container">
    {featuredPosts.map((post) => (
      <div class="min-w-full h-80 flex flex-col justify-end p-8 bg-gradient-to-t from-black/80 to-transparent">
        <h2 class="text-3xl font-bold text-white mb-2">{post.data.title}</h2>
        <p class="text-gray-200 line-clamp-2">{post.data.description}</p>
        <a href={`/posts/${post.slug}`} class="mt-4 inline-block text-accent font-semibold hover:underline">
          Read More →
        </a>
      </div>
    ))}
  </div>
  
  <button id="prev" class="absolute left-4 top-1/2 bg-white/20 p-2 rounded-full text-white">←</button>
  <button id="next" class="absolute right-4 top-1/2 bg-white/20 p-2 rounded-full text-white">→</button>
</div>

<script>
  const container = document.getElementById('slider-container');
  const next = document.getElementById('next');
  const prev = document.getElementById('prev');
  let current = 0;

  next?.addEventListener('click', () => {
    current = (current + 1) % 5;
    container!.style.transform = `translateX(-${current * 100}%)`;
  });

  prev?.addEventListener('click', () => {
    current = (current - 1 + 5) % 5;
    container!.style.transform = `translateX(-${current * 100}%)`;
  });
</script>
