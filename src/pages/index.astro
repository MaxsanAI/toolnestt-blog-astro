---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/Card.astro";
import FeaturedSlider from "@/components/FeaturedSlider.astro";
import Search from "@/components/Search.astro"; // Pretpostavljam da je ovde prava komponenta
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getUniqueTags } from "@/utils/getUniqueTags";

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const popularPosts = sortedPosts.slice(0, 4);
const allTags = getUniqueTags(posts);
---

<Layout title="Naslovna">
  <section id="hero-slider" class="mb-10">
    <FeaturedSlider />
  </section>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    <aside class="hidden md:block md:col-span-2 space-y-6">
      <h3 class="font-bold uppercase text-sm border-b pb-2">Kategorije</h3>
      <ul class="space-y-2 text-sm">
        {allTags.map(({ tag, tagName }) => (
          <li>
            <a href={`/tags/${tag}`} class="hover:text-accent capitalize">
              {tagName || tag}
            </a>
          </li>
        ))}
      </ul>
    </aside>

    <section class="md:col-span-7">
      <h2 class="text-2xl font-semibold mb-6">Najnovije</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {recentPosts.slice(0, 6).map(post => <Card {...post} />)}
      </div>
    </section>

    <aside class="md:col-span-3 space-y-6">
      <div class="p-5 border rounded-lg">
        <Search client:load searchList={sortedPosts} />
      </div>
      <div class="p-5 border rounded-lg">
        <h3 class="font-bold mb-4">Popularno</h3>
        <ul class="space-y-4">
          {popularPosts.map(post => (
            <li>
              <a href={`/posts/${post.id}`} class="text-sm hover:text-accent">
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  </div>
</Layout>
