---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import config from "@/config";

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured).slice(0, 5);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  
  <main id="main-content" class="mx-auto max-w-7xl px-4 py-6">
    
    <section id="hero-slider" class="mb-10">
      <h2 class="text-xl font-bold mb-4 uppercase tracking-wider">Featured Stories</h2>
      <div class="h-80 w-full rounded-xl bg-gray-800 flex items-center justify-center text-white">
        <p>Slider Placeholder (Top 5 Featured)</p>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      
      <aside class="hidden md:block md:col-span-2 space-y-6">
        <h3 class="font-bold uppercase text-sm border-b pb-2">Tech Categories</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="hover:text-accent">Artificial Intelligence</a></li>
          <li><a href="#" class="hover:text-accent">Web Development</a></li>
          <li><a href="#" class="hover:text-accent">Cybersecurity</a></li>
          <li><a href="#" class="hover:text-accent">Cloud Computing</a></li>
          <li><a href="#" class="hover:text-accent">Software Engineering</a></li>
        </ul>

        <h3 class="font-bold uppercase text-sm border-b pb-2 pt-4">Tools & How-To</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="hover:text-accent">PDF Utilities</a></li>
          <li><a href="#" class="hover:text-accent">Image Processing</a></li>
          <li><a href="#" class="hover:text-accent">Code Snippets</a></li>
          <li><a href="#" class="hover:text-accent">Productivity Tools</a></li>
          <li><a href="#" class="hover:text-accent">Tutorials</a></li>
        </ul>
      </aside>

      <section class="md:col-span-7">
        <h2 class="text-2xl font-semibold mb-6">Latest Updates</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {recentPosts.slice(0, 6).map(post => <Card {...post} />)}
        </div>
      </section>

      <aside class="md:col-span-3 space-y-6">
        <div class="p-5 border border-gray-200 rounded-lg dark:border-gray-700">
          <h3 class="font-bold mb-4">Newsletter</h3>
          <p class="text-sm mb-4">Subscribe for the latest tech news.</p>
          <input type="email" placeholder="Your email" class="w-full p-2 border rounded text-sm mb-2" />
          <button class="w-full bg-accent text-white py-2 rounded text-sm">Subscribe</button>
        </div>
        
        <div class="p-5 border border-gray-200 rounded-lg dark:border-gray-700">
          <h3 class="font-bold mb-4">Popular Posts</h3>
        </div>
      </aside>

    </div>
  </main>
  
  <Footer />
</Layout>
