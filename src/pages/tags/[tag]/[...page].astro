---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro"; // Ako ovo pukne, proveri da li je putanja Layout.astro
import Card from "@/components/Card.astro";

// Koristimo direktan fetch umesto sumnjivih utils-a dok ne vidimo strukturu
export async function getStaticPaths() {
  const posts = await getCollection("posts");
  // Izvlači sve jedinstvene tagove
  const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))];
  
  return allTags.flatMap((tag) => {
    const tagPosts = posts.filter(post => post.data.tags?.includes(tag));
    return Array.from({ length: Math.ceil(tagPosts.length / 5) }, (_, i) => ({
      params: { tag, page: String(i + 1) },
      props: { posts: tagPosts.slice(i * 5, (i + 1) * 5) },
    }));
  });
}

type Props = {
  posts: CollectionEntry<"posts">[];
};

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={`Tag: ${tag}`}>
  <main class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-2xl font-bold mb-6 capitalize">Tag: {tag}</h1>
    <ul>
      {posts.map((post: CollectionEntry<"posts">) => <Card {...post} />)}
    </ul>
  </main>
</Layout>
